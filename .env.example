POSTGRES_PASSWORD=replace-with-a-long-random-password
ADMIN_USERNAME=admin
# Argon2id hash only. Generate: cd backend && uv run python -c "from vietnam_calendar.security import hash_password; import getpass; print(hash_password(getpass.getpass()))"
# Compose bootstrap is create-only. Rotate explicitly with:
# docker compose run --rm migrate python -m vietnam_calendar.bootstrap --rotate-password
ADMIN_PASSWORD_HASH=
APP_ENV=development
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=false
RSS_ALLOWED_HOSTS=news.tuoitre.vn
RSS_USER_AGENT=VietnamCalendar/0.1
# Optional operator/contact URL or email included in User-Agent parentheses.
RSS_CONTACT=
RSS_MAX_BODY_BYTES=5242880
RSS_TOTAL_TIMEOUT=90
RSS_MAX_ENTRIES=500
RSS_MAX_RAW_ENTRY_BYTES=65536
WORKER_POLL_SECONDS=2
WORKER_LEASE_SECONDS=120
# Docker Compose interpolates `$` in values. When placing an Argon2 hash in this
# env file, escape each literal `$` as `$$`; prefer a secret file/store outside development.
AI_PROVIDER=disabled
AI_FALLBACK_PROVIDER=disabled
AI_AUTO_FALLBACK=false
AI_TIMEOUT_SECONDS=45
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=
